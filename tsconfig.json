{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "noImplicitAny": true
  },
  "include": ["src/**/*", "bin/**/*", "server.ts", "server.ts", "factory", "loaders", "factory", "transforms", "persistence", "loaders", "writers", "writers"]
}
